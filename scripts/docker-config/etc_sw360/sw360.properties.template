## API Token generation
rest.write.access.usergroup=USER
rest.admin.access.usergroup=ADMIN
rest.apitoken.read.validity.days=90
rest.apitoken.write.validity.days=30
rest.apitoken.hash.salt=$REST_APITOKEN_HASH_SALT

# where the Thrift should connect
backend.url=http://127.0.0.1:8080

org.eclipse.sw360.licensinfo.projectclearing.templatemapping=Default:templateReport
enable.sw360.change.log=false

# ---------------------------------------
# Email Properties
# ---------------------------------------

# settings for the mail utility:
# if host is not set, e-mailing is disabled
MailUtil_host=$EMAIL_PROPERTIES_HOST
MailUtil_from=$EMAIL_PROPERTIES_FROM
MailUtil_port=$EMAIL_PROPERTIES_PORT
MailUtil_enableStarttls=$EMAIL_PROPERTIES_STARTTLS
MailUtil_enableSsl=$EMAIL_PROPERTIES_ENABLE_SSL
MailUtil_isAuthenticationNecessary=$EMAIL_PROPERTIES_AUTH_REQUIRED
MailUtil_login=$EMAIL_PROPERTIES_USERNAME
MailUtil_password=$EMAIL_PROPERTIES_PASSWORD
MailUtil_enableDebug=$EMAIL_PROPERTIES_DEBUG
MailUtil_supportMailAddress=$EMAIL_PROPERTIES_SUPPORT_EMAIL
MailUtil_smtpSSLProtocol=$EMAIL_PROPERTIES_TLS_PROTOCOL
MailUtil_smtpSSLTrust=$EMAIL_PROPERTIES_TLS_TRUST

