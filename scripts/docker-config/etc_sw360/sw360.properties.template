svm.sw360.api.url=$SVM_SW360_API_URL
svm.sw360.certificate.filename=$SVM_SW360_CERTIFICATE_FILENAME
svm.sw360.certificate.passphrase=$SVM_SW360_CERTIFICATE_PASSPHRASE
